<?php $this->extend('block_searchable'); ?>

<?php $this->block('content'); ?>

<div class="container">
    <div class="row">
        <div class="<?= $this->containerWidth ?>">
            <?php if ($this->elements) : ?>
                <?php foreach ($this->elements as $element) : ?>
                    <?= $this->parseElement($element) ?>
                <?php endforeach; ?>
            <?php endif; ?>
        </div>
    </div>
</div>

<?php $this->endblock(); ?>